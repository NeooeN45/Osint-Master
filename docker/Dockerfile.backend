FROM node:20-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    whois curl dnsutils nmap \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy backend
COPY backend/package*.json ./
RUN npm ci --production

COPY backend/ ./

# Build TypeScript
RUN npx tsc || true

EXPOSE 3002

CMD ["npx", "tsx", "src/server.ts"]
