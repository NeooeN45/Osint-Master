# ============================================================
# OSINT Master Pro — Variables d'environnement
# Copiez ce fichier en .env et remplissez les clés voulues.
# Les modules sans clé restent disponibles (APIs publiques).
# ============================================================

# ---- Serveur ----
PORT=3002
NODE_ENV=development

# ---- RapidAPI (clé unique, débloque : LinkedIn, TikTok, YouTube, Twitch, Spotify, Discord, Veriphone, Email validation...) ----
# https://rapidapi.com — tier gratuit = 500 req/mois
RAPIDAPI_KEY=

# ---- Shodan (IP/domaine, infra) ----
# https://account.shodan.io
SHODAN_API_KEY=

# ---- Have I Been Pwned ----
# https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# ---- AbuseIPDB ----
# https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# ---- Hunter.io (email finder) ----
# https://hunter.io/api-keys — tier gratuit = 25 req/mois
HUNTER_API_KEY=

# ---- IPinfo.io (geoloc IP sans clé = 50k req/mois) ----
IPINFO_TOKEN=

# ---- NumVerify (téléphone) ----
# https://numverify.com
NUMVERIFY_API_KEY=

# ---- GitHub (commit email harvest, user search) ----
# https://github.com/settings/tokens — aucun scope requis (public repos)
GITHUB_TOKEN=

# ---- Brave Search API (dorking) ----
# https://api.search.brave.com — tier gratuit = 2000 req/mois
BRAVE_SEARCH_KEY=

# ---- Bing Search API (dorking fallback) ----
# https://azure.microsoft.com/fr-fr/services/cognitive-services/bing-web-search-api
BING_SEARCH_KEY=

# ---- Abstract API (phone + email validation) ----
# https://www.abstractapi.com
ABSTRACT_PHONE_KEY=
ABSTRACT_EMAIL_KEY=

# ---- Google Knowledge Graph ----
# https://developers.google.com/knowledge-graph
GOOGLE_KG_KEY=

# ---- Proxycurl (LinkedIn scrape professionnel) ----
# https://nubela.co/proxycurl — payant mais précis
PROXYCURL_KEY=

# ---- VirusTotal ----
# https://www.virustotal.com/gui/user/apikey
VIRUSTOTAL_KEY=

# ---- Censys ----
# https://search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=

# ---- Intelx (Intelligence X — paste search) ----
# https://intelx.io/account
INTELX_API_KEY=

# ---- Dehashed (leak DB) ----
# https://dehashed.com/profile
DEHASHED_EMAIL=
DEHASHED_API_KEY=

# ---- LeakCheck ----
# https://leakcheck.io/api
LEAKCHECK_API_KEY=

# ---- Twilio (SMS / phone validation) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ---- Telegram Bot (lookup amélioré) ----
TELEGRAM_BOT_TOKEN=

# ---- SpiderFoot (chemin si installé) ----
# Laisser vide si sf.py est dans PATH
SPIDERFOOT_PATH=

# ---- Ollama (AI local, analyse et corrélations) ----
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
